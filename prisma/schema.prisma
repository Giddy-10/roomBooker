// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique // Enforces school email uniquely
  password  String?   // Nullable for users who register exclusively via Google OAuth
  googleId  String?   @unique // Captured via Google OAuth registration/login
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Room {
  id             String     @id @default(uuid())
  name           String
  capacity       Int
  category       String     // "solo" or "group"
  location       String
  isOutOfService Boolean    @default(false) // Total room shutdown flag
  facilities     Facility[] // Relation field to individual components
  bookings       Booking[]
  tickets        Ticket[]
}

model Facility {
  id             String  @id @default(uuid())
  name           String  // e.g., "WiFi", "Smartboard", "Whiteboard", "Projector"
  isOutOfService Boolean @default(false) // Tracks if this specific item is broken
  roomId         String
  room           Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String   @id @default(uuid())
  roomId      String
  facility    String   // Stores the name of the reported facility (e.g., "WiFi")
  description String
  status      String   @default("OPEN") // "OPEN" or "RESOLVED"
  createdAt   DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String   @id @default(uuid())
  userId     String
  roomId     String
  startTime  DateTime // Combines selected date and start time
  endTime    DateTime // Calculated automatically via user-selected duration
  groupSize  Int      // Checked against room capacity thresholds during booking
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  room       Room     @relation(fields: [roomId], references: [id])

  @@index([roomId, startTime, endTime]) // Speeds up double-booking conflict queries
}
